# Database
DATABASE_URL=postgresql://ocr_bank_user:ocr_bank_password@localhost:5432/ocr_bank
POSTGRES_USER=ocr_bank_user
POSTGRES_PASSWORD=ocr_bank_password
POSTGRES_DB=ocr_bank

# VLM (Vision Language Model for OCR)
GROQ_API_KEY=your_groq_api_key_here

# LLM (Primary: Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini

# LLM (Local: LM Studio)
LOCAL_LLM_URL=http://localhost:1234/v1

# Vector Store
CHROMADB_PERSIST_DIRECTORY=./backend/data/chromadb

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_PATH=./backend/config/credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# File Storage
IMAGE_STORAGE_PATH=./backend/images
MAX_UPLOAD_SIZE=10485760

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
