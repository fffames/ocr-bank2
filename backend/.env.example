# Database (set in deployment platform)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# API Keys (set in deployment platform - NEVER commit real keys)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# OCR Configuration
OCR_LANGUAGE=th
OCR_DEVICE=cpu
OCR_ENGINE=tesseract

# LLM Configuration
LLM_PROVIDER=gemini

# VLM Configuration
VLM_PROVIDER=gemini
VLM_FALLBACK_ENABLED=true

# Vector Store - Pinecone (Recommended for cloud deployment - free tier)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=ocr-bank-receipts
PINECONE_ENVIRONMENT=us-east-1-aws

# Vector Store - ChromaDB (Local development only - NOT for cloud)
# CHROMADB_PERSIST_DIRECTORY=/tmp/chromadb

# File Storage (production: use /tmp or cloud storage)
IMAGE_STORAGE_PATH=/tmp/ocr_images
MAX_UPLOAD_SIZE=10485760

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS (update with your frontend domain)
CORS_ORIGINS=https://your-frontend-domain.com

# Authentication (CHANGE IN PRODUCTION - generate secure random key)
SECRET_KEY=change-this-to-a-secure-random-key-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google Sheets (optional)
GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEETS_SPREADSHEET_ID=
