# Backend Production Environment Variables for Railway
# Copy these to Railway Variables tab (not as a file)

# ========== DATABASE ==========
# Get from Supabase: Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres

# ========== OCR ==========
OCR_LANGUAGE=th
OCR_DEVICE=cpu

# ========== LLM ==========
# Use Groq for free tier (faster, more reliable)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxx
LLM_PROVIDER=groq

# ========== VLM ==========
# For cloud deployment, use Groq VLM (not LM Studio)
VLM_PROVIDER=groq
LOCAL_LLM_URL=

# ========== VECTOR STORE ==========
# Use Railway persistent disk (/data volume)
CHROMADB_PERSIST_DIRECTORY=/data/chromadb

# ========== GOOGLE SHEETS ==========
# Spreadsheet ID from your Google Sheet
GOOGLE_SHEETS_SPREADSHEET_ID=1kIPkLNIRmHJv1Y1admnoLigFh0iycS-9GUIymxvJDoU

# Note: credentials.json needs to be uploaded via base64 encoding
# Add GOOGLE_SHEETS_CREDENTIALS_BASE64 variable in Railway

# ========== FILE STORAGE ==========
# Use Railway persistent disk (/data volume)
IMAGE_STORAGE_PATH=/data/images
MAX_UPLOAD_SIZE=10485760

# ========== CORS ==========
# Comma-separated list of allowed frontend URLs
CORS_ORIGINS=https://your-frontend.vercel.app,https://ocr-bank.vercel.app

# ========== API ==========
# Railway sets this automatically, but you can override
PORT=8000
