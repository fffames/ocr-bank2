FROM python:3.11-slim

WORKDIR /app

# Install minimal dependencies
RUN pip install fastapi uvicorn pydantic-settings python-dotenv

# Copy config and simple app
COPY backend/app/config.py ./app/
COPY backend/app/main_simple.py ./app/
COPY backend/.env.example .env

# Create necessary directories
RUN mkdir -p /app/images /app/data/chromadb /app/uploads

# Expose port
EXPOSE 8000

# Run the simple app
CMD ["python", "-m", "uvicorn", "app.main_simple:app", "--host", "0.0.0.0", "--port", "8000"]