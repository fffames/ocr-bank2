FROM python:3.11-slim

WORKDIR /app

# Install only FastAPI and Uvicorn
RUN pip install fastapi uvicorn

# Copy ONLY the test app file
COPY backend/app/main_test.py .

# Create log directory
RUN mkdir -p /tmp/logs

# Expose port
EXPOSE 8000

# Run the test app directly with Railway's PORT
CMD ["sh", "-c", "echo 'Starting app...' && python main_test.py"]